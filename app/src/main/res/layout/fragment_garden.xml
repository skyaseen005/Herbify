<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/green_dark">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/garden_banner"
            android:scaleType="centerCrop"
            android:alpha="0.4" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌻"
                android:textSize="40sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/my_garden_title"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tv_plant_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 plants"
                android:textColor="@color/green_pale"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/ll_empty_garden"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌱"
            android:textSize="64sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/garden_empty"
            android:textColor="@color/gray_medium"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btn_go_explore"
            style="@style/HerbifyButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore Plants"
            android:layout_marginTop="24dp" />
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_garden"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false" />

</LinearLayout>