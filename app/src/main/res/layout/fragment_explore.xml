<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/green_dark"
        android:padding="20dp"
        android:paddingTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore Plants"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover thousands of herbal species"
            android:textColor="@color/green_pale"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <!-- Search Bar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/search_layout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/search_hint"
            app:hintTextColor="@color/green_pale"
            app:boxStrokeColor="@color/green_light"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/green_pale">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:background="@android:color/transparent" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/white"
        android:paddingVertical="10dp">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_all"
                style="@style/HerbifyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_edible"
                style="@style/HerbifyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🥗 Edible" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_indoor"
                style="@style/HerbifyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠 Indoor" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_perennial"
                style="@style/HerbifyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♾️ Perennial" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_annual"
                style="@style/HerbifyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Annual" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_full_sun"
                style="@style/HerbifyChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️ Full Sun" />
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/green_medium"
        android:layout_marginTop="40dp" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌿"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_plants"
            android:textColor="@color/gray_medium"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_plants"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="10dp"
        android:clipToPadding="false" />

    <!-- Load more button -->
    <Button
        android:id="@+id/btn_load_more"
        style="@style/HerbifyButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="16dp"
        android:text="Load More"
        android:visibility="gone" />

</LinearLayout>