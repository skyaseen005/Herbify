<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Banner -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="240dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/home_banner"
                android:scaleType="centerCrop" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/overlay_green" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 Herbify"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif-light"
                    android:letterSpacing="0.05" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tagline"
                    android:textColor="@color/green_pale"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.1" />

                <Button
                    android:id="@+id/btn_explore_now"
                    style="@style/HerbifyButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore Plants"
                    android:layout_marginTop="20dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Why Herbal Plants Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/why_herbal"
                style="@style/HerbifyTitle"
                android:textSize="20sp"
                android:layout_marginBottom="4dp" />

            <View
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/amber"
                android:layout_marginBottom="16dp" />

            <!-- Cards Grid 2x3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/HerbifyCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌱" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_1_title" android:textColor="@color/green_dark" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_1_desc" android:textColor="@color/gray_medium" android:textSize="11sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    style="@style/HerbifyCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧠" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_2_title" android:textColor="@color/green_dark" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_2_desc" android:textColor="@color/gray_medium" android:textSize="11sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/HerbifyCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥦" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_3_title" android:textColor="@color/green_dark" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_3_desc" android:textColor="@color/gray_medium" android:textSize="11sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    style="@style/HerbifyCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="♻️" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_4_title" android:textColor="@color/green_dark" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_4_desc" android:textColor="@color/gray_medium" android:textSize="11sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    style="@style/HerbifyCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍽️" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_5_title" android:textColor="@color/green_dark" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_5_desc" android:textColor="@color/gray_medium" android:textSize="11sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    style="@style/HerbifyCard">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌬️" android:textSize="28sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_6_title" android:textColor="@color/green_dark" android:textStyle="bold" android:textSize="13sp" android:layout_marginTop="6dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/importance_6_desc" android:textColor="@color/gray_medium" android:textSize="11sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>

        <!-- Quick Tip Banner -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/green_dark">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="32sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Did You Know?"
                        android:textColor="@color/amber"
                        android:textStyle="bold"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Over 80% of the world\'s population relies on herbal medicine for primary healthcare needs."
                        android:textColor="@color/green_pale"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>